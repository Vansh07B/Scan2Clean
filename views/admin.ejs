<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | Scan2Clean</title>
  <link rel="icon" href="/images/favicon.ico">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Poppins', sans-serif; }
  </style>
</head>
<body class="bg-gray-50">

<!-- Navigation -->
<nav class="fixed w-full bg-white shadow-md z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="flex items-center space-x-2">
        <i data-feather="cpu" class="text-emerald-600 w-6 h-6"></i>
        <span class="font-bold text-xl text-gray-800">Scan2Clean Admin</span>
      </div>
      <div class="space-x-4 hidden md:flex">
        <a href="/" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-md text-sm font-medium">Main Site</a>
      </div>
    </div>
  </div>
</nav>

<!-- Hero / Header Section -->
<section class="pt-32 pb-8 bg-emerald-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-2">Admin Dashboard 🧹</h1>
    <p class="text-gray-600 text-lg md:text-xl">Manage and resolve campus cleanliness reports efficiently</p>
  </div>
</section>

<!-- Statistics Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
  <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-xl transition">
    <h2 class="text-2xl font-bold text-gray-800"><%= reports.length %></h2>
    <p class="text-gray-500">Total Reports</p>
  </div>
  <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-xl transition">
    <h2 class="text-2xl font-bold text-yellow-600"><%= reports.filter(r => !r.resolved).length %></h2>
    <p class="text-gray-500">Pending Reports</p>
  </div>
  <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-xl transition">
    <h2 class="text-2xl font-bold text-green-600"><%= reports.filter(r => r.resolved).length %></h2>
    <p class="text-gray-500">Resolved Reports</p>
  </div>
</section>

<!-- Filter Buttons -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 flex justify-center space-x-3">
  <a href="/admin" class="bg-white border border-emerald-600 text-emerald-600 px-4 py-2 rounded-lg font-medium hover:bg-emerald-50 transition">All</a>
  <a href="/admin?filter=pending" class="bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-emerald-700 transition">Pending</a>
  <a href="/admin?filter=resolved" class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg font-medium hover:bg-gray-400 transition">Resolved</a>
</div>

<!-- Reports Grid -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
  <% if (reports.length === 0) { %>
    <p class="text-center text-gray-500 text-lg mt-12">No reports found for this filter.</p>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% reports.forEach(report => { %>
        <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-xl transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-2"><%= report.location %></h3>
          <p class="text-gray-500 text-sm mb-2"><strong>Date:</strong> <%= report.date %> | <strong>Time:</strong> <%= report.time %></p>
          <p class="text-gray-700 mb-4"><%= report.description %></p>
          
          <% if (report.image) { %>
            <img src="/images/<%= report.image %>" alt="Report Image" class="w-full h-48 object-cover rounded-lg mb-4">
          <% } %>

          <p class="mb-4">
            <span class="px-3 py-1 rounded-full text-sm font-semibold <%= report.resolved ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
              <%= report.resolved ? '✅ Resolved' : '🟡 Pending' %>
            </span>
          </p>

          <div class="flex flex-wrap gap-2">
            <% if (!report.resolved) { %>
              <form action="/resolve/<%= report._id %>" method="POST">
                <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg font-medium transition">Mark Resolved</button>
              </form>
            <% } %>
            <form action="/delete/<%= report._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this report?');">
              <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg font-medium transition">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Footer -->
<footer class="mt-12 bg-gray-100 py-6 text-center text-gray-600">
  © 2025 Scan2Clean Project | Developed by Team EcoCoders
</footer>

<script>
  feather.replace();
</script>
</body>
</html>
