<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Login | Scan2Clean</title>
<link rel="icon" href="/images/favicon.ico">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/feather-icons"></script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  body { font-family: 'Poppins', sans-serif; background: linear-gradient(135deg, #a8f0c6, #f0fdf4); }
</style>
</head>
<body class="min-h-screen flex items-center justify-center">

<div class="max-w-md w-full bg-white rounded-3xl shadow-2xl p-10 animate-fadeIn">
  <div class="text-center mb-6">
    <div class="flex items-center justify-center mb-6">
      <div class="flex-shrink-0 flex items-center">
        <i data-feather="cpu" class="text-emerald-600 h-6 w-6"></i>
        <span class="ml-2 text-xl font-bold text-gray-800">Scan2Clean</span>
      </div>
    </div>
    <h2 class="text-4xl font-bold text-gray-900">Admin Login</h2>
    <p class="text-gray-500 mt-2">Secure access to manage reports</p>
  </div>
  
  <% if (error) { %>
    <p class="text-red-500 text-center mb-4 font-medium"><%= error %></p>
  <% } %>

  <form action="/admin/login" method="POST" class="flex flex-col gap-5">
    <input type="text" name="username" placeholder="Username" required
      class="w-full px-5 py-4 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 shadow-sm transition">
    <input type="password" name="password" placeholder="Password" required
      class="w-full px-5 py-4 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 shadow-sm transition">
    <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white py-4 rounded-xl font-semibold shadow-lg transition duration-300">
      Login
    </button>
  </form>

  <p class="text-center text-gray-500 mt-6 text-sm">
    Back to <a href="/" class="text-emerald-600 hover:underline font-medium">Main Page</a>
  </p>
</div>

<script>
  feather.replace();
</script>

</body>
</html>
